# EditorConfig helps developers define and maintain consistent
# coding styles between different editors and IDEs
# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Use spaces for the hand-authored text formats in this repository.
[*.{json,lock,md,nix,pl,pm,py,rb,sh,toml,xml,yaml,yml}]
indent_style = space

[justfile]
indent_style = space
indent_size = 2

# Match docbook files, set indent width of one
[*.xml]
indent_size = 1

# Match two-space configuration and documentation formats.
[*.{json,lock,md,nix,rb,toml,yaml,yml}]
indent_size = 2

# Match perl/python/shell scripts, set indent width of four
[*.{pl,pm,py,sh}]
indent_size = 4
